library(tidyverse)
library(dsbox)
library(mosaicData)
staff <- read_csv("data/instructional-staff.csv")
staff_long <- staff %>%
pivot_longer(cols = -faculty_type, names_to = "year") %>%
mutate(value = as.numeric(value))
staff_long
staff_long %>%
ggplot(aes(x = year, y = value, color = faculty_type)) +
geom_line()
staff_long %>%
ggplot(aes(
x = year,
y = value,
group = faculty_type,
color = faculty_type
)) +
geom_line()
staff_plot <-
ggplot(staff_long, aes(
x = year,
y = value,
group = faculty_type,
color = faculty_type
)) +
labs(title = "Instructional Staff Employment Trends", x = "Year", y = "Percentage", color = "Faculty Type") +
theme(plot.title = element_text(hjust = 0.5)) +
geom_line()
ggsave(staff_plot, file="staff_plot.pdf", width = 12, height = 4)
View(staff)
View(staff_long)
View(staff)
part_time_staff <- staff %>%
t() %>%
as.data.frame()
View(part_time_staff)
View(staff)
View(staff)
part_time_staff <- staff %>%
column_to_rownames(var = "year") %>%
t() %>%
as.data.frame()
View(staff)
part_time_staff <- staff %>%
column_to_rownames(var = "faculty_type") %>%
t() %>%
as.data.frame()
View(part_time_staff)
colnames(part_time_staff)
View(part_time_staff)
View(staff)
